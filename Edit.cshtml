@model EmsPotral.Models.Emp

@{
    ViewData["Title"] = "Update Employee";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0">

        <div class="card-header bg-warning text-dark">
            <h2 class="mb-0">✏️ Update Employee Details</h2>
        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Employee ID</label>
                        <input asp-for="EmpId" class="form-control" readonly />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Employee Name</label>
                        <input asp-for="EmpName" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Email Address</label>
                        <input asp-for="EmailID" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Age</label>
                        <input asp-for="Age" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Phone Number</label>
                        <input asp-for="Phoneno" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Department</label>
                        <input asp-for="Role" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Salary</label>
                        <input asp-for="Salary" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Manager Name</label>
                        <input asp-for="MrgName" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Joining Date</label>
                        <input asp-for="JoiningDate"
                               type="date"
                               class="form-control" />
                    </div>

                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-warning">
                        💾 Update Employee
                    </button>

                    <a asp-action="Index" class="btn btn-secondary">
                        ↩ Back
                    </a>
                </div>

            </form>

        </div>
    </div>

    @if (ViewBag.Message != null)
    {
        <div class="alert alert-success mt-4">
            @ViewBag.Message
        </div>
    }

    @if (Model != null)
    {
        <div class="card shadow mt-4 border-0">

            <div class="card-header bg-info text-white">
                <h4 class="mb-0">👤 Updated Employee Details</h4>
            </div>

            <div class="card-body">

                <div class="row">

                    <div class="col-md-6 mb-2">
                        <strong>ID:</strong> @Model.EmpId
                    </div>

                    <div class="col-md-6 mb-2">
                        <strong>Name:</strong> @Model.EmpName
                    </div>

                    <div class="col-md-6 mb-2">
                        <strong>Email:</strong> @Model.EmailID
                    </div>

                    <div class="col-md-6 mb-2">
                        <strong>Age:</strong> @Model.Age
                    </div>

                    <div class="col-md-6 mb-2">
                        <strong>Phone:</strong> @Model.Phoneno
                    </div>

                    <div class="col-md-6 mb-2">
                        <strong>Department:</strong> @Model.Role
                    </div>

                    <div class="col-md-6 mb-2">
                        <strong>Salary:</strong> ₹@Model.Salary
                    </div>

                    <div class="col-md-6 mb-2">
                        <strong>Manager:</strong> @Model.MrgName
                    </div>

                    <div class="col-md-6 mb-2">
                        <strong>Joining Date:</strong>
                        @Model.JoiningDate.ToString("dd-MMM-yyyy")
                    </div>

                </div>

            </div>

        </div>
    }

</div>