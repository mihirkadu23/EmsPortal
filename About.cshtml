@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary">About Employee Management System</h1>
        <p class="lead text-muted">
            A modern solution for managing employee records efficiently.
        </p>
    </div>

    <div class="card shadow border-0 mb-4">
        <div class="card-body p-4">
            <h3 class="text-primary mb-3">Overview</h3>
            <p>
                The <strong>Employee Management System (EMS)</strong> is a web-based application
                developed using ASP.NET Core MVC and Entity Framework Core.
            </p>

            <p>
                This system helps organizations efficiently manage employee information such as
                personal details, job roles, salaries, and joining dates.
            </p>
        </div>
    </div>

    <div class="row g-4">

        <!-- Features -->
        <div class="col-md-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <h4 class="text-success mb-3">
                        <i class="bi bi-check-circle-fill"></i> Key Features
                    </h4>

                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">➕ Add New Employees</li>
                        <li class="list-group-item">👁️ View Employee Details</li>
                        <li class="list-group-item">✏️ Edit Employee Information</li>
                        <li class="list-group-item">🗑️ Delete Employee Records</li>
                        <li class="list-group-item">💰 Manage Salary Information</li>
                        <li class="list-group-item">📅 Track Joining Dates</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Purpose -->
        <div class="col-md-6">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <h4 class="text-info mb-3">
                        <i class="bi bi-bullseye"></i> Purpose
                    </h4>

                    <p>
                        The primary goal of this project is to simplify employee data management,
                        reduce manual record keeping, and improve operational efficiency.
                    </p>

                    <p>
                        It also demonstrates CRUD (Create, Read, Update, Delete) operations
                        using ASP.NET Core MVC and Entity Framework Core.
                    </p>
                </div>
            </div>
        </div>

    </div>

    <!-- Technology Stack -->
    <div class="card shadow border-0 mt-4">
        <div class="card-body p-4">
            <h3 class="text-warning mb-3">
                <i class="bi bi-code-slash"></i> Technology Stack
            </h3>

            <div class="row text-center">
                <div class="col-md-3 mb-3">
                    <div class="p-3 bg-light rounded">
                        <h5>ASP.NET Core MVC</h5>
                    </div>
                </div>

                <div class="col-md-3 mb-3">
                    <div class="p-3 bg-light rounded">
                        <h5>Entity Framework Core</h5>
                    </div>
                </div>

                <div class="col-md-3 mb-3">
                    <div class="p-3 bg-light rounded">
                        <h5>SQL Server</h5>
                    </div>
                </div>

                <div class="col-md-3 mb-3">
                    <div class="p-3 bg-light rounded">
                        <h5>C#</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-primary mt-4 shadow-sm">
        <strong>Note:</strong> This project is designed for learning and understanding
        full-stack web development using Microsoft technologies.
    </div>

</div>